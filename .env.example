# Exemplo de variáveis de ambiente para o PetControl SaaS
# Copie este arquivo para .env e preencha as suas chaves reais.

# Supabase
VITE_SUPABASE_URL="SUA_URL_DO_SUPABASE"
VITE_SUPABASE_ANON_KEY="SUA_CHAVE_ANON_DO_SUPABASE"

# Klivopay (Necessário para pagamentos e notificações)
KLIVOPAY_API_TOKEN="SEU_TOKEN_DA_API_KLIVOPAY"
KLIVOPAY_WEBHOOK_SECRET="SEU_SECRET_DO_WEBHOOK_KLIVOPAY"

# Outras configurações (opcional)
VITE_APP_URL="http://localhost:5173"
